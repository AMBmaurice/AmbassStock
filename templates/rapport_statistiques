<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <title>AmbassStock - Rapport d'Audit Institutionnel</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif; background-color: #ffffff; color: #333333; padding: 50px; max-width: 900px; margin: 0 auto; line-height: 1.5; }
        
        .btn-back-actions { display: flex; gap: 15px; margin-bottom: 40px; }
        .btn-nav { height: 44px; padding: 0 20px; border-radius: 10px; font-size: 0.95rem; font-weight: 600; cursor: pointer; border: none; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; transition: background-color 0.2s; }
        .btn-return { background-color: #ECEFEA; color: #5E6D3E; }
        .btn-return:hover { background-color: #E2E6E1; }
        .btn-print-now { background-color: #5E6D3E; color: #ffffff; }
        .btn-print-now:hover { background-color: #495430; }
        
        .diplomatic-header { border-bottom: 2px solid #5E6D3E; padding-bottom: 20px; margin-bottom: 40px; }
        .institution-title { font-size: 1.35rem; font-weight: 700; color: #2c351c; text-transform: uppercase; letter-spacing: 0.5px; }
        .document-nature { font-size: 1.1rem; color: #7A8278; margin-top: 5px; font-weight: 500; }
        
        .meta-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 15px; background-color: #FAFBF9; padding: 20px; border-radius: 12px; border: 1px solid #ECEFEA; margin-bottom: 35px; font-size: 0.95rem; }
        
        h2 { font-size: 1.25rem; font-weight: 600; color: #495430; margin: 35px 0 15px 0; border-bottom: 1px solid #ECEFEA; padding-bottom: 8px; text-transform: uppercase; letter-spacing: 0.3px; }
        p { font-size: 1rem; color: #444444; margin-bottom: 20px; text-align: justify; }
        
        .report-table { width: 100%; border-collapse: collapse; text-align: left; margin: 20px 0 30px 0; }
        .report-table th { background-color: #FAFBF9; padding: 12px 14px; font-size: 0.82rem; color: #7A8278; font-weight: 700; text-transform: uppercase; border-bottom: 2px solid #D0D6CE; letter-spacing: 0.5px; }
        .report-table td { padding: 14px; font-size: 0.95rem; border-bottom: 1px solid #ECEFEA; color: #333333; }
        
        .badge-status { font-weight: 600; padding: 4px 8px; border-radius: 6px; font-size: 0.85rem; text-transform: uppercase; }
        .status-ok { background-color: #EBF2E9; color: #5E6D3E; }
        .status-alert { background-color: #F9EBEB; color: #8C4A32; }

        .distribution-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 40px; margin: 30px 0; }
        .chart-donut-wrapper { position: relative; height: 240px; width: 100%; }

        .ref-tag { font-family: monospace; font-weight: 600; color: #5E6D3E; background: #EBF2E9; padding: 4px 8px; border-radius: 6px; }

        @media print {
            .btn-back-actions { display: none !important; }
            body { padding: 0; }
        }
    </style>
</head>
<body>

    <div class="btn-back-actions">
        <a href="/statistiques/" class="btn-nav btn-return">Retour aux statistiques</a>
        <button class="btn-nav btn-print-now" onclick="window.print()">Lancer l'impression officielle</button>
    </div>

    <div class="diplomatic-header">
        <div class="institution-title">Délégation Permanente de la République de Maurice auprès de l'UNESCO</div>
        <div class="document-nature">Rapport d'Audit Stratégique et Logistique des Stocks</div>
    </div>

    <div class="meta-grid">
        <div><strong>Type d'Analyse :</strong> {{ type_analyse|capfirst }}</div>
        <div><strong>Période de Référence :</strong> {{ periode_a }} {% if periode_b %}vs {{ periode_b }}{% endif %}</div>
        <div><strong>Généré Automatiquement le :</strong> Document Certifié AmbassStock</div>
        <div><strong>Statut de la Mission :</strong> Confidentiel / Usage Interne</div>
    </div>

    <h2>1. Synthèse Générale et Indicateurs de Performance (KPIs)</h2>
    <p>Ce chapitre récapitule la réactivité des flux et comptabilise l'intensité opérationnelle de l'activité sur la période cible sélectionnée.</p>
    
    <table class="report-table">
        <thead>
            <tr>
                <th>Indicateur Logistique</th>
                <th>Valeur Constatée</th>
                <th>Seuil de Vigilance</th>
                <th>Diagnostic Automatique</th>
            </tr>
        </thead>
        <tbody>
            <tr>
                <td>Volume Global des Mouvements</td>
                <td>{{ total_operations }} fiches</td>
                <td>--</td>
                <td><span class="badge-status status-ok">{{ statut_general }}</span></td>
            </tr>
            <tr>
                <td>Taux de Rotation Global</td>
                <td>{{ taux_rotation }}%</td>
                <td>&gt; 15%</td>
                <td><span class="badge-status status-ok">Ajusté</span></td>
            </tr>
            {% for kpi in kpis_avances %}
            <tr>
                <td>{{ kpi.nom }}</td>
                <td>{{ kpi.valeur }}</td>
                <td>{{ kpi.seuil }}</td>
                <td><span class="badge-status {% if kpi.diag == 'Alerte Espace' or kpi.diag == 'Régression' %}status-alert{% else %}status-ok{% endif %}">{{ kpi.diag }}</span></td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    
    {% if inclure_remarques %}
    <p><strong>Remarque de l'auditeur automatisé :</strong> {{ synthese_generale }}</p>
    {% endif %}

    <!-- SECTION 2 : TABLEAUX ET MATRICES LOGISTIQUES ADAPTATIFS -->
    {% if tableau_specifique %}
        <h2>2. Matrice d'Analyse Spécifique du Rapport</h2>
        
        {% if tableau_specifique.type == 'alertes_mensuelles' %}
        <p>Les articles suivants présentent un risque critique d'indisponibilité physique en réserve à très court terme compte tenu de la cadence d'utilisation constatée.</p>
        <table class="report-table">
            <thead>
                <tr>
                    <th>Référence</th>
                    <th>Désignation de l'Objet</th>
                    <th>Stock Actuel</th>
                    <th>Quantité Consommée (30j)</th>
                </tr>
            </thead>
            <tbody>
                {% for item in tableau_specifique.donnees %}
                <tr>
                    <td><span class="ref-tag">{{ item.reference }}</span></td>
                    <td><strong>{{ item.objet }}</strong></td>
                    <td style="color: #8C4A32; font-weight: 700;">{{ item.stock }} unités</td>
                    <td>{{ item.consomme }} unités</td>
                </tr>
                {% empty %}
                <tr>
                    <td colspan="4" class="empty-state" style="text-align: center; color: #A0A69F; font-style: italic; padding: 20px;">Aucun risque de rupture de stock identifié sous 15 jours.</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% endif %}

        {% if tableau_specifique.type == 'palmares_annuel' %}
        <p>Récapitulatif de la charge de distribution et poids volumétrique des consommations des différents services de la délégation sur le cycle annuel.</p>
        <table class="report-table">
            <thead>
                <tr>
                    <th>Service Demandeur</th>
                    <th>Volume Retiré</th>
                    <th>Quote-Part Globale</th>
                </tr>
            </thead>
            <tbody>
                {% for p in tableau_specifique.donnees %}
                <tr>
                    <td><strong>{{ p.service }}</strong></td>
                    <td>{{ p.total }} unités</td>
                    <td>{{ p.part }}%</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% endif %}

        {% if tableau_specifique.type == 'ecarts_mensuels' %}
        <p>Tableau d'analyse différentielle par catégorie de consommables entre la période de référence (A) et la période de comparaison (B).</p>
        <table class="report-table">
            <thead>
                <tr>
                    <th>Catégorie de Produits</th>
                    <th>Volume Période A</th>
                    <th>Volume Période B</th>
                    <th>Écart Absolu</th>
                </tr>
            </thead>
            <tbody>
                {% for e in tableau_specifique.donnees %}
                <tr>
                    <td><strong>{{ e.categorie }}</strong></td>
                    <td>{{ e.mois_a }}</td>
                    <td>{{ e.mois_b }}</td>
                    <td style="font-weight: 700; color: {% if e.ecart >= 0 %}#8C4A32{% else %}#5E6D3E{% endif %};">
                        {% if e.ecart >= 0 %}+{% endif %}{{ e.ecart }}
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% endif %}

        {% if tableau_specifique.type == 'trajectoire_annuelle' %}
        <p>Mesure de l'évolution structurelle à long terme des indicateurs de gestion des stocks de la délégation active.</p>
        <table class="report-table">
            <thead>
                <tr>
                    <th>Indicateur Macro</th>
                    <th>Cycle A</th>
                    <th>Cycle B</th>
                    <th>Évolution Nette</th>
                </tr>
            </thead>
            <tbody>
                {% for t in tableau_specifique.donnees %}
                <tr>
                    <td><strong>{{ t.indicateur }}</strong></td>
                    <td>{{ t.annee_a }}</td>
                    <td>{{ t.annee_b }}</td>
                    <td style="font-weight: 700;">{{ t.evolution }}</td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
        {% endif %}
    {% endif %}

    {% if inclure_graphiques %}
    <h2>3. Graphiques Analytiques de Répartition Sectorielle</h2>
    <p>Visualisation de la ventilation des demandes logistiques par pôle administratif et par typologie de ressources.</p>

    <div class="distribution-grid">
        <div>
            <div class="chart-donut-wrapper">
                <canvas id="repService"></canvas>
            </div>
        </div>
        <div>
            <div class="chart-donut-wrapper">
                <canvas id="repCat"></canvas>
            </div>
        </div>
    </div>
    {% endif %}

    {% if inclure_remarques %}
        <p><strong>Analyse automatique sectorielle :</strong> {{ remarque_sectorielle }}</p>
        <p><strong>Diagnostic de l'immobilisation des ressources :</strong> {{ remarque_dormant }}</p>
    {% endif %}

    {% if inclure_dormants %}
    <h2>4. Liste des Marchandises Dormantes (Inactives +180 jours)</h2>
    <p>Ce volet isole les références stockées en réserve n'ayant enregistré aucun flux de mouvement récent, représentant un encombrement passif de l'espace.</p>
    
    <table class="report-table">
        <thead>
            <tr>
                <th>Référence</th>
                <th>Désignation de l'objet</th>
                <th>Emplacement de Réserve</th>
                <th>Quantité Physique</th>
            </tr>
        </thead>
        <tbody>
            {% for p in produits_dormants %}
            <tr>
                <td><span class="ref-tag">{{ p.reference }}</span></td>
                <td><strong>{{ p.objet }}</strong></td>
                <td>{{ p.emplacement }}</td>
                <td>{{ p.quantite }} unités</td>
            </tr>
            {% empty %}
            <tr>
                <td colspan="4" style="text-align: center; color: #A0A69F; font-style: italic; padding: 30px;">Aucun produit dormant détecté dans les réserves sur cette période.</td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
    {% endif %}

    {% if inclure_graphiques %}
    <script>
        const ctxS = document.getElementById('repService').getContext('2d');
        new Chart(ctxS, {
            type: 'doughnut',
            data: {
                labels: {{ service_labels|safe }},
                datasets: [{ 
                    data: {{ service_data }}, 
                    backgroundColor: ['#5E6D3E', '#495430', '#8C4A32', '#A0A69F', '#D0D6CE'],
                    borderWidth: 2,
                    borderColor: '#ffffff'
                }]
            },
            options: { 
                responsive: true, 
                maintainAspectRatio: false, 
                plugins: { title: { display: true, text: 'Consommation par Service (%)', color: '#2c351c', font: { weight: 'bold', size: 12 } } } 
            }
        });

        const ctxC = document.getElementById('repCat').getContext('2d');
        new Chart(ctxC, {
            type: 'doughnut',
            data: {
                labels: {{ category_labels|safe }},
                datasets: [{ 
                    data: {{ category_data }}, 
                    backgroundColor: ['#5E6D3E', '#8C4A32', '#A0A69F', '#495430', '#D0D6CE', '#7A8278'],
                    borderWidth: 2,
                    borderColor: '#ffffff'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: { title: { display: true, text: 'Répartition par Catégorie (%)', color: '#2c351c', font: { weight: 'bold', size: 12 } } } 
            }
        });
    </script>
    {% endif %}
</body>
</html>
